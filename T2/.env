#  Configuración Redis / Cache
# Tamaño máximo de la cache en Redis (probar 50mb, 200mb, 500mb)
REDIS_MAXMEMORY=200mb
# Política NATIVA de Redis
# - allkeys-lru  → para CACHE_POLICY=LRU
# - allkeys-lfu  → para CACHE_POLICY=LFU
# - noeviction   → para CACHE_POLICY=FIFO (manejado por cliente)
REDIS_POLICY_NATIVE=allkeys-lru
REDIS_PORT_HOST=6379

# Política a nivel del cache_service. Valores válidos: LRU, LFU, FIFO
CACHE_POLICY=LRU

# TTL global default (segundos). 0 = sin expiración.
CACHE_TTL_SEC=300

# TTL específicos por tipo de consulta
TTL_Q1=300
TTL_Q2=300
TTL_Q3=180
TTL_Q4=120
TTL_Q5=600

# Latencia simulada del Response Generator (ms) 
# Aproxima el costo de un cómputo geoespacial real
SIM_LATENCY_MIN_MS=30
SIM_LATENCY_MAX_MS=120

# Tarea 2: Kafka / arquitectura asíncrona
# Puerto del broker Kafka expuesto al host (para inspección con kafka-cli local)
KAFKA_PORT_HOST=9092
# Máximo de reintentos antes de expulsar un mensaje a la DLQ
# retry_count parte en 0; al alcanzar MAX_RETRIES el mensaje va a consultas_dlq
MAX_RETRIES=3
# Backoff (ms) antes de re-encolar un mensaje a consultas_reintentos
# tiempo al Generador de Respuestas a recuperarse, de modo que los reintentos
# tengan éxito (recovery) en vez de agotarse instantáneamente hacia la DLQ
RETRY_DELAY_MS=1000
PARTITIONS_MAIN=6
