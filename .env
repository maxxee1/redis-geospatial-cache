# --- Configuración Redis / Caché ---
# Tamaño máximo de la caché en Redis (probar 50mb, 200mb, 500mb)
REDIS_MAXMEMORY=200mb
# Política NATIVA de Redis. Solo se usa si CACHE_POLICY = LRU o LFU.
# - allkeys-lru  → para CACHE_POLICY=LRU
# - allkeys-lfu  → para CACHE_POLICY=LFU
# - noeviction   → para CACHE_POLICY=FIFO (manejado por cliente)
REDIS_POLICY_NATIVE=allkeys-lru
REDIS_PORT_HOST=6379

# Política a nivel del cache_service. Valores válidos: LRU, LFU, FIFO.
# Asegúrate de que coincida con REDIS_POLICY_NATIVE (excepto para FIFO).
CACHE_POLICY=LRU

# TTL global default (segundos). 0 = sin expiración.
CACHE_TTL_SEC=300

# TTL específicos por tipo de consulta
TTL_Q1=300
TTL_Q2=300
TTL_Q3=180
TTL_Q4=120
TTL_Q5=600

# --- Latencia simulada del Response Generator (ms) ---
# Aproxima el costo de un cómputo geoespacial real
SIM_LATENCY_MIN_MS=30
SIM_LATENCY_MAX_MS=120
